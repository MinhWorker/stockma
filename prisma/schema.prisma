// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  emailVerified     Boolean            @default(false)
  image             String?
  transactions      StockTransaction[]
  returnTransactions ReturnTransaction[]
  debtPayments      DebtPayment[]
  activityLogs      ActivityLog[]
  pushSubscriptions PushSubscription[]
  sessions          Session[]
  accounts          Account[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Inventory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  items       Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  shortDescription String?
  description      String?
  imageUrl         String?
  brand            String?
  // costPrice: gia nhap, dung de tinh doanh thu (ban - nhap)
  costPrice        Int
  // price: gia ban le
  price            Int
  // unit: don vi tinh (tuy chon)
  unit             String?
  categoryId       Int
  category         ProductCategory    @relation(fields: [categoryId], references: [id])
  providerId       Int
  provider         Provider           @relation(fields: [providerId], references: [id])
  inventoryId      Int
  inventory        Inventory          @relation(fields: [inventoryId], references: [id])
  transactions     StockTransaction[]
  variants         ProductVariant[]
  returnTransactions ReturnTransaction[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ProductVariant {
  id           Int                @id @default(autoincrement())
  productId    Int
  product      Product            @relation(fields: [productId], references: [id])
  name         String
  costPrice    Int?
  price        Int?
  unit         String?
  transactions StockTransaction[]
  returnTransactions ReturnTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([productId, name])
}

model ProductCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
  state     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Provider {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  provideItems Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// StockTransaction ghi lai moi lan nhap/xuat/dieu chinh kho.
// Ton kho hien tai = SUM(quantity) cua tat ca transactions theo productId,
// trong do stock_in va adjustment la duong, stock_out la am.
model StockTransaction {
  id          Int              @id @default(autoincrement())
  type        TransactionType
  // quantity: so duong cho stock_in/adjustment, so am cho stock_out
  quantity    Int
  // stockBefore / stockAfter: snapshot tai thoi diem giao dich
  stockBefore Int
  stockAfter  Int
  note        String?
  productId   Int
  product     Product          @relation(fields: [productId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  // New fields
  variantId            Int?
  variant              ProductVariant?   @relation(fields: [variantId], references: [id])
  stockOutType         StockOutType?
  salePrice            Int?
  purchasePrice        Int?
  isGift               Boolean           @default(false)
  parentTransactionId  Int?
  parentTransaction    StockTransaction? @relation("GiftItems", fields: [parentTransactionId], references: [id])
  giftItems            StockTransaction[] @relation("GiftItems")
  returnTransactionId  Int?
  returnTransaction    ReturnTransaction? @relation(fields: [returnTransactionId], references: [id])
  debtGroup            DebtGroup?
  createdAt   DateTime         @default(now())
}

enum TransactionType {
  stock_in
  stock_out
  adjustment
}

enum StockOutType {
  retail
  wholesale
  transfer
}

model ReturnTransaction {
  id             Int              @id @default(autoincrement())
  productId      Int
  product        Product          @relation(fields: [productId], references: [id])
  variantId      Int?
  variant        ProductVariant?  @relation(fields: [variantId], references: [id])
  returnQty      Int
  replacementQty Int
  purchasePrice  Int?
  note           String?
  transactions   StockTransaction[]
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  createdAt      DateTime         @default(now())
}

model DebtGroup {
  id            Int          @id @default(autoincrement())
  transactionId Int          @unique
  transaction   StockTransaction @relation(fields: [transactionId], references: [id])
  debtorName    String
  totalAmount   Int
  paidAmount    Int          @default(0)
  status        DebtStatus   @default(open)
  payments      DebtPayment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum DebtStatus {
  open
  closed
  cancelled
}

model DebtPayment {
  id          Int       @id @default(autoincrement())
  debtGroupId Int
  debtGroup   DebtGroup @relation(fields: [debtGroupId], references: [id])
  amount      Int
  note        String?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id          Int            @id @default(autoincrement())
  action      ActivityAction
  entityType  String
  entityId    Int?
  entityName  String?
  description String
  inventoryId Int?
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  createdAt   DateTime       @default(now())
}

enum ActivityAction {
  create
  update
  delete
  export
}

// Push notification subscriptions per user
model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  // Notification preferences
  lowStock        Boolean @default(true)
  stockOut        Boolean @default(true)
  newTransaction  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// System
model ModelState {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
